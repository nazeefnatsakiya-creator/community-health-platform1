# Copy this to .env locally, or set these as environment variables in
# Railway/Render. Never commit real secrets to git.

PERSONAL_DB_URL=postgresql://user:password@host:5432/chp_personal
ANALYTICS_DB_URL=postgresql://user:password@host:5432/chp_analytics
REDIS_URL=redis://host:6379/0

# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=replace-with-a-long-random-string
FIELD_ENCRYPTION_KEY=replace-with-another-long-random-string

ENVIRONMENT=production
